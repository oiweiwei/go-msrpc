import "ms-dtyp.idl";

cpp_quote( "#define TS_PROCESS_INFO_MAGIC_NT4  0x23495452" )
  
typedef struct _TS_PROCESS_INFORMATION_NT4 {
     ULONG MagicNumber;
     ULONG LogonId;
     PVOID ProcessSid;
     ULONG Pad;
} TS_PROCESS_INFORMATION_NT4, * PTS_PROCESS_INFORMATION_NT4;
  
