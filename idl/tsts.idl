     ULONG SpareUl3;
     SIZE_T PeakVirtualSize;
     SIZE_T VirtualSize;
     ULONG PageFaultCount;
     ULONG PeakWorkingSetSize;
     ULONG WorkingSetSize;
     SIZE_T QuotaPeakPagedPoolUsage;
